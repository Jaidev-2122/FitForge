# ============================================================
# FitForge (single-user, no-auth) environment variables
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
# ============================================================

# Flask session signing secret (used for the lightweight name cookie).
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# --- Supabase ---
SUPABASE_URL=https://vvhczndpkhrxclmccbut.supabase.co
# Service-role key: single-user personal app with no login, so the server uses
# the service-role key to read/write your one profile. Server-side only, gitignored.
SUPABASE_SERVICE_KEY=

# --- Gemini 2.5 Flash (server-side only) ---
# Free tier available. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
